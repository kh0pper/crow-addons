# Plex connection
# Find your token: see the plex skill or visit app.plex.tv,
# open browser DevTools > Network, look for X-Plex-Token in any API request
PLEX_URL=http://localhost:32400
PLEX_TOKEN=
PLEX_MACHINE_ID=

# Docker self-host mode only
PLEX_MEDIA_PATH=/path/to/media
PLEX_CONFIG_PATH=
PLEX_CLAIM_TOKEN=
