# IPTV Bundle — Environment Variables
# All optional. The IPTV server works with zero config.

# Directory for recorded streams (default: ~/.crow/data/iptv-recordings)
# CROW_IPTV_RECORDINGS_PATH=~/.crow/data/iptv-recordings

# EPG refresh interval in hours (default: 12)
# CROW_IPTV_EPG_REFRESH_HOURS=12
