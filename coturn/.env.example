# coturn TURN server configuration
# Generate a random secret: openssl rand -hex 32
TURN_SECRET=your_random_secret_here

# Domain/realm (usually your hostname or domain)
TURN_REALM=crow.local

# Public IP (required for remote access, leave empty for LAN-only)
# TURN_EXTERNAL_IP=203.0.113.1

# Port (default 3478)
# TURN_PORT=3478
