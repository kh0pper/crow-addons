# Nextcloud connection (for existing instance or new deployment)
NEXTCLOUD_URL=http://localhost:8080
NEXTCLOUD_USER=admin
NEXTCLOUD_PASSWORD=

# WebDAV mount path (where Nextcloud files appear on the host)
NEXTCLOUD_MOUNT_PATH=/mnt/nextcloud

# Database passwords (only needed for new deployment via docker-compose)
NEXTCLOUD_DB_PASSWORD=changeme
NEXTCLOUD_DB_ROOT_PASSWORD=rootchangeme
