# Media Hub — Environment Variables
# All optional. The media server works with zero config.

# Max concurrent RSS fetches per background tick (default: 3)
# CROW_MEDIA_MAX_FETCHES=3

# Disable AI analysis, TTS, and email digest tasks (for Pi Zero/1)
# CROW_MEDIA_LITE=1

# Daily token budget for AI article analysis (default: unlimited)
# CROW_MEDIA_AI_DAILY_TOKEN_BUDGET=50000

# TTS audio cache max size in MB (default: 500)
# CROW_MEDIA_AUDIO_MAX_MB=500

# Daily TTS generation limit (default: 50)
# CROW_MEDIA_TTS_DAILY_LIMIT=50

# SMTP for email digests (requires: npm install nodemailer)
# CROW_SMTP_HOST=smtp.gmail.com
# CROW_SMTP_PORT=587
# CROW_SMTP_USER=
# CROW_SMTP_PASS=
# CROW_SMTP_FROM=
