{
  "id": "minio",
  "name": "File Storage (MinIO)",
  "version": "1.0.0",
  "description": "S3-compatible file storage — upload, organize, and share files through Crow",
  "type": "bundle",
  "author": "Crow",
  "category": "storage",
  "tags": ["storage", "files", "s3", "upload", "self-hosted"],
  "icon": "archive",
  "docker": {
    "composefile": "docker-compose.yml"
  },
  "requires": {
    "env": ["MINIO_ROOT_PASSWORD"],
    "min_ram_mb": 256,
    "min_disk_mb": 500
  },
  "env_vars": [
    {
      "name": "MINIO_ENDPOINT",
      "description": "MinIO API host",
      "default": "localhost",
      "required": true
    },
    {
      "name": "MINIO_PORT",
      "description": "MinIO API port",
      "default": "9000",
      "required": true
    },
    {
      "name": "MINIO_ROOT_USER",
      "description": "MinIO admin username",
      "default": "crowadmin",
      "required": true
    },
    {
      "name": "MINIO_ROOT_PASSWORD",
      "description": "MinIO admin password (choose a strong password)",
      "required": true,
      "secret": true
    },
    {
      "name": "MINIO_USE_SSL",
      "description": "Use SSL for MinIO connection",
      "default": "false",
      "required": false
    }
  ],
  "ports": [9000, 9001],
  "webUI": { "port": 9001, "path": "/", "label": "Console", "proxyMode": "direct" },
  "notes": "After installation, Crow's storage tools (upload, list, delete files) will be available automatically. The MinIO console is accessible at http://localhost:9001."
}
