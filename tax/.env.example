# Crow Tax — Environment Variables

# Required: Passphrase for encrypting PII (SSN, names) at rest
CROW_TAX_ENCRYPTION_KEY=change-this-to-a-strong-passphrase

# Optional: Path to tax database (defaults to Crow's main DB)
# CROW_TAX_DB_PATH=/path/to/tax.db

# Optional: VNC password for browser automation container
# VNC_PASSWORD=crowtax
