{
  "id": "vllm-cuda-embed",
  "name": "vLLM Embeddings (Qwen3-Embedding-0.6B)",
  "version": "1.0.0",
  "description": "Multilingual text embeddings (Qwen3-Embedding-0.6B, 1024-dim Matryoshka). Powers semantic search across memory, research notes, and blog. CUDA only.",
  "type": "bundle",
  "author": "Crow",
  "category": "ai",
  "tags": [
    "ai",
    "embeddings",
    "semantic-search",
    "cuda",
    "vllm"
  ],
  "icon": "cpu",
  "docker": {
    "composefile": "docker-compose.yml"
  },
  "requires": {
    "gpu": true,
    "min_vram_gb": 2,
    "platform": "linux-x86_64",
    "gpu_arch": [
      "cuda"
    ]
  },
  "port": 9100,
  "host": "49cf71ca878643ba7717f344329266fd",
  "providers": [
    {
      "id": "grackle-embed",
      "baseUrlTemplate": "http://{host_ip}:{port}/v1",
      "apiKey": "none",
      "description": "Text embeddings via Qwen3-Embedding-0.6B (grackle, always warm)",
      "models": [
        {
          "id": "qwen3-embedding-0.6b",
          "task": "embed",
          "dim": 1024,
          "matryoshkaDims": [
            1024,
            768,
            512,
            256
          ],
          "warm": true,
          "priority": "interactive"
        }
      ]
    }
  ],
  "notes": "Always-warm. Pairs with vllm-cuda-rerank. Steady-state ~1.6GB VRAM."
}
